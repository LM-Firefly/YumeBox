{
  "openapi": "3.1.0",
  "info": {
    "title": "Mihomo 外部控制器 API",
    "version": "1.0.0",
    "description": "Mihomo（clash.meta）内核通过外部控制器（external-controller）暴露的 RESTful API，可用于查询状态、切换节点、测试延迟、管理连接等。TCP / TLS 外部控制器在配置了 secret 时需要携带 Bearer 密钥；Unix socket / Windows named pipe 访问不会校验 secret。可在右侧 Try it 面板中将服务器地址 host/port 修改为你自己的后端地址（mihomo 示例配置为 http://127.0.0.1:9093）。"
  },
  "servers": [
    {
      "url": "http://{host}:{port}",
      "variables": {
        "host": {
          "default": "127.0.0.1",
          "description": "外部控制器监听地址 / mihomo 后端的局域网 IP。"
        },
        "port": {
          "default": "9093",
          "description": "外部控制器监听端口；默认值对齐 mihomo 示例配置 external-controller: 0.0.0.0:9093。"
        }
      }
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "日志",
      "description": "实时日志流。"
    },
    {
      "name": "流量信息",
      "description": "实时上下行流量统计。"
    },
    {
      "name": "内存信息",
      "description": "实时内存占用统计。"
    },
    {
      "name": "版本信息",
      "description": "内核版本信息。"
    },
    {
      "name": "缓存",
      "description": "FakeIP / DNS 缓存清理。"
    },
    {
      "name": "运行配置",
      "description": "运行配置的读取、重载与修改。"
    },
    {
      "name": "更新",
      "description": "内核、面板与 GEO 数据库的更新。"
    },
    {
      "name": "策略组",
      "description": "策略组的查询与延迟测试。"
    },
    {
      "name": "代理",
      "description": "代理节点的查询、选择与延迟测试。"
    },
    {
      "name": "代理集合",
      "description": "代理集合（proxy provider）的查询、更新与健康检查。"
    },
    {
      "name": "规则",
      "description": "规则的查询与临时禁用。"
    },
    {
      "name": "规则集合",
      "description": "规则集合（rule provider）的查询与更新。"
    },
    {
      "name": "连接",
      "description": "连接信息的查询与关闭。"
    },
    {
      "name": "域名查询",
      "description": "通过内核 DNS 进行域名解析。"
    },
    {
      "name": "存储",
      "description": "内核键值存储的读写。"
    },
    {
      "name": "DEBUG",
      "description": "调试相关端点（需内核日志级别为 debug）。"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "在请求头中携带 Authorization: Bearer ${secret}，其中 secret 对应配置中的 secret 字段。若未设置 secret 可省略，但强烈建议设置。"
      }
    },
    "schemas": {
      "PathPayloadBody": {
        "type": "object",
        "description": "路径 / 内容载荷。path 指定配置文件路径，payload 直接传入配置内容；二者均可留空以使用当前配置。",
        "properties": {
          "path": {
            "type": "string",
            "example": ""
          },
          "payload": {
            "type": "string",
            "example": ""
          }
        }
      },
      "Proxy": {
        "type": "object",
        "description": "代理节点或策略组的信息。",
        "properties": {
          "name": {
            "type": "string",
            "example": "默认"
          },
          "type": {
            "type": "string",
            "example": "Selector"
          },
          "now": {
            "type": "string",
            "description": "当前选中的节点（仅策略组）。",
            "example": "日本"
          },
          "all": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "组内全部成员名称（仅策略组）。",
            "example": [
              "默认",
              "香港"
            ]
          },
          "udp": {
            "type": "boolean",
            "example": true
          },
          "hidden": {
            "type": "boolean",
            "example": false
          },
          "icon": {
            "type": "string",
            "example": ""
          },
          "history": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DelayHistory"
            }
          }
        }
      },
      "DelayHistory": {
        "type": "object",
        "properties": {
          "time": {
            "type": "string",
            "example": "2026-06-22T10:00:00.000Z"
          },
          "delay": {
            "type": "integer",
            "example": 109
          }
        }
      },
      "DelayMap": {
        "type": "object",
        "description": "节点名 → 延迟(ms) 的映射。",
        "additionalProperties": {
          "type": "integer"
        },
        "example": {
          "示例节点 A": 66,
          "示例节点 B": 86
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          }
        }
      }
    }
  },
  "paths": {
    "/": {
      "get": {
        "tags": [
          "版本信息"
        ],
        "operationId": "hello",
        "responses": {
          "200": {
            "description": "连通性检查成功。",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "hello": {
                      "type": "string"
                    }
                  }
                },
                "example": {
                  "hello": "mihomo"
                }
              }
            }
          }
        },
        "summary": "连通性检查"
      }
    },
    "/logs": {
      "get": {
        "tags": [
          "日志"
        ],
        "operationId": "getLogs",
        "parameters": [
          {
            "name": "level",
            "in": "query",
            "required": false,
            "description": "日志级别过滤。",
            "schema": {
              "type": "string",
              "enum": [
                "info",
                "warning",
                "error",
                "debug"
              ]
            }
          },
          {
            "name": "format",
            "in": "query",
            "required": false,
            "description": "日志格式，传入 structured 获取结构化日志。",
            "schema": {
              "type": "string",
              "enum": [
                "structured"
              ]
            }
          },
          {
            "name": "once",
            "in": "query",
            "required": false,
            "description": "设置为 true 时立即返回最近日志数组；不设置时保持实时流式输出。",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "token",
            "in": "query",
            "required": false,
            "description": "仅 WebSocket 场景使用。浏览器无法设置 Authorization 头时，可用 token=${secret} 进行鉴权。",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "默认流式日志，每条一行 JSON；once=true 时返回日志数组。",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "type": "object",
                      "properties": {
                        "type": {
                          "type": "string",
                          "example": "info"
                        },
                        "payload": {
                          "type": "string",
                          "example": "..."
                        }
                      }
                    },
                    {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "type": {
                            "type": "string",
                            "example": "info"
                          },
                          "payload": {
                            "type": "string",
                            "example": "..."
                          }
                        }
                      }
                    }
                  ]
                },
                "example": [
                  {
                    "type": "info",
                    "payload": "RESTful API listening at: 127.0.0.1:9093"
                  }
                ]
              }
            }
          }
        },
        "summary": "获取实时日志"
      }
    },
    "/traffic": {
      "get": {
        "tags": [
          "流量信息"
        ],
        "operationId": "getTraffic",
        "parameters": [
          {
            "name": "once",
            "in": "query",
            "required": false,
            "description": "设置为 true 时立即返回当前流量快照；不设置时保持实时流式输出。",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "token",
            "in": "query",
            "required": false,
            "description": "仅 WebSocket 场景使用。浏览器无法设置 Authorization 头时，可用 token=${secret} 进行鉴权。",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "默认流式流量数据，每秒一行 JSON；once=true 时立即返回一次快照。",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "up": {
                      "type": "integer",
                      "description": "上行字节/秒。"
                    },
                    "down": {
                      "type": "integer",
                      "description": "下行字节/秒。"
                    },
                    "upTotal": {
                      "type": "integer",
                      "description": "累计上行字节。"
                    },
                    "downTotal": {
                      "type": "integer",
                      "description": "累计下行字节。"
                    }
                  }
                },
                "example": {
                  "up": 58527,
                  "down": 154391,
                  "upTotal": 1747227807,
                  "downTotal": 1106864138
                }
              }
            }
          }
        },
        "summary": "获取实时流量"
      }
    },
    "/memory": {
      "get": {
        "tags": [
          "内存信息"
        ],
        "operationId": "getMemory",
        "parameters": [
          {
            "name": "once",
            "in": "query",
            "required": false,
            "description": "设置为 true 时立即返回当前内存快照；不设置时保持实时流式输出。",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "token",
            "in": "query",
            "required": false,
            "description": "仅 WebSocket 场景使用。浏览器无法设置 Authorization 头时，可用 token=${secret} 进行鉴权。",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "默认流式内存数据；once=true 时立即返回一次快照。",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "inuse": {
                      "type": "integer",
                      "description": "当前使用字节数。"
                    },
                    "oslimit": {
                      "type": "integer",
                      "description": "系统内存限制字节数。"
                    }
                  }
                },
                "example": {
                  "inuse": 0,
                  "oslimit": 0
                }
              }
            }
          }
        },
        "summary": "获取实时内存占用"
      }
    },
    "/version": {
      "get": {
        "tags": [
          "版本信息"
        ],
        "operationId": "getVersion",
        "responses": {
          "200": {
            "description": "版本信息。",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "meta": {
                      "type": "boolean"
                    },
                    "version": {
                      "type": "string"
                    }
                  }
                },
                "example": {
                  "meta": true,
                  "version": "alpha-a52a27ed"
                }
              }
            }
          }
        },
        "summary": "获取版本信息"
      }
    },
    "/cache/fakeip/flush": {
      "post": {
        "tags": [
          "缓存"
        ],
        "operationId": "flushFakeipCache",
        "responses": {
          "204": {
            "description": "清除成功，无返回内容。"
          }
        },
        "summary": "清除 FakeIP 缓存"
      }
    },
    "/cache/dns/flush": {
      "post": {
        "tags": [
          "缓存"
        ],
        "operationId": "flushDnsCache",
        "responses": {
          "204": {
            "description": "清除成功，无返回内容。"
          }
        },
        "summary": "清除 DNS 缓存"
      }
    },
    "/configs": {
      "get": {
        "tags": [
          "运行配置"
        ],
        "operationId": "getConfigs",
        "responses": {
          "200": {
            "description": "当前运行配置。",
            "content": {
              "application/json": {
                "example": {
                  "mixed-port": 7890,
                  "mode": "rule",
                  "log-level": "info",
                  "allow-lan": true,
                  "ipv6": false,
                  "tun": {
                    "enable": false
                  }
                }
              }
            }
          }
        },
        "summary": "获取基本配置"
      },
      "put": {
        "tags": [
          "运行配置"
        ],
        "operationId": "reloadConfigs",
        "parameters": [
          {
            "name": "force",
            "in": "query",
            "required": false,
            "description": "是否强制重载。",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PathPayloadBody"
              },
              "example": {
                "path": "",
                "payload": ""
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "重载成功，无返回内容。"
          }
        },
        "summary": "重新加载基本配置"
      },
      "patch": {
        "tags": [
          "运行配置"
        ],
        "operationId": "patchConfigs",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": true
              },
              "examples": {
                "切换模式": {
                  "value": {
                    "mode": "rule"
                  }
                },
                "修改端口": {
                  "value": {
                    "mixed-port": 7890
                  }
                }
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "更新成功，无返回内容。"
          }
        },
        "summary": "更新基本配置"
      }
    },
    "/configs/geo": {
      "post": {
        "tags": [
          "运行配置"
        ],
        "operationId": "updateGeoDatabase",
        "responses": {
          "204": {
            "description": "更新成功，无返回内容。"
          }
        },
        "summary": "更新 GEO 数据库"
      }
    },
    "/restart": {
      "post": {
        "tags": [
          "运行配置"
        ],
        "operationId": "restartCore",
        "responses": {
          "200": {
            "description": "已接受重启请求。",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string"
                    }
                  }
                },
                "example": {
                  "status": "ok"
                }
              }
            }
          }
        },
        "summary": "重启内核"
      }
    },
    "/upgrade": {
      "post": {
        "tags": [
          "更新"
        ],
        "operationId": "upgradeCore",
        "parameters": [
          {
            "name": "channel",
            "in": "query",
            "required": false,
            "description": "更新通道。",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "force",
            "in": "query",
            "required": false,
            "description": "是否强制更新。",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "更新成功。",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string"
                    }
                  }
                },
                "example": {
                  "status": "ok"
                }
              }
            }
          }
        },
        "summary": "更新内核"
      }
    },
    "/upgrade/ui": {
      "post": {
        "tags": [
          "更新"
        ],
        "operationId": "upgradeUi",
        "responses": {
          "200": {
            "description": "更新成功。",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string"
                    }
                  }
                },
                "example": {
                  "status": "ok"
                }
              }
            }
          }
        },
        "summary": "更新面板"
      }
    },
    "/upgrade/geo": {
      "post": {
        "tags": [
          "更新"
        ],
        "operationId": "upgradeGeo",
        "responses": {
          "204": {
            "description": "更新成功，无返回内容。"
          }
        },
        "summary": "更新 GEO 数据库"
      }
    },
    "/group": {
      "get": {
        "tags": [
          "策略组"
        ],
        "operationId": "getGroups",
        "responses": {
          "200": {
            "description": "策略组列表。",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "proxies": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Proxy"
                      }
                    }
                  }
                },
                "example": {
                  "proxies": [
                    {
                      "name": "默认",
                      "type": "Selector",
                      "now": "日本",
                      "all": [
                        "默认",
                        "香港"
                      ],
                      "hidden": false,
                      "icon": ""
                    }
                  ]
                }
              }
            }
          }
        },
        "summary": "获取所有策略组"
      }
    },
    "/group/{name}": {
      "get": {
        "tags": [
          "策略组"
        ],
        "operationId": "getGroupByName",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "description": "策略组名称。",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "策略组信息。",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Proxy"
                },
                "example": {
                  "name": "默认",
                  "type": "Selector",
                  "now": "日本",
                  "all": [
                    "默认",
                    "香港",
                    "台湾",
                    "日本",
                    "美国",
                    "新加坡"
                  ],
                  "hidden": false,
                  "icon": "",
                  "history": []
                }
              }
            }
          }
        },
        "summary": "获取指定策略组"
      }
    },
    "/group/{name}/delay": {
      "get": {
        "tags": [
          "策略组"
        ],
        "operationId": "getGroupDelay",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "description": "策略组名称。",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "url",
            "in": "query",
            "required": true,
            "description": "延迟测试目标 URL。",
            "schema": {
              "type": "string",
              "example": "https://www.gstatic.com/generate_204"
            }
          },
          {
            "name": "timeout",
            "in": "query",
            "required": true,
            "description": "超时时间（毫秒）。源码中该参数缺失或非整数会返回 400。",
            "schema": {
              "type": "integer",
              "example": 5000
            }
          },
          {
            "name": "expected",
            "in": "query",
            "required": false,
            "description": "期望的 HTTP 状态码，支持范围如 200-299。",
            "schema": {
              "type": "string",
              "example": "200-299"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "节点名 → 延迟(ms) 的映射。",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DelayMap"
                },
                "example": {
                  "示例节点 A": 66,
                  "示例节点 B": 86,
                  "示例节点 C": 83
                }
              }
            }
          }
        },
        "summary": "测试策略组内节点延迟"
      }
    },
    "/proxies": {
      "get": {
        "tags": [
          "代理"
        ],
        "operationId": "getProxies",
        "responses": {
          "200": {
            "description": "代理列表。",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "proxies": {
                      "type": "object",
                      "additionalProperties": {
                        "$ref": "#/components/schemas/Proxy"
                      }
                    }
                  }
                },
                "example": {
                  "proxies": {
                    "GLOBAL": {
                      "type": "Selector",
                      "now": "DIRECT",
                      "all": []
                    },
                    "示例节点 D": {
                      "type": "Shadowsocks",
                      "history": [
                        {
                          "time": "...",
                          "delay": 109
                        }
                      ],
                      "udp": true
                    }
                  }
                }
              }
            }
          }
        },
        "summary": "获取所有代理"
      }
    },
    "/proxies/{name}": {
      "get": {
        "tags": [
